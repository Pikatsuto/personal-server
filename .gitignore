# Build artefacts generated by build/generate.sh and build/build.sh.
# Everything under build/ that is NOT a template or a script is transient.
build/Dockerfile
build/docker-bake.hcl
build/report.json
build/manifest.txt
build/logs/

# Test artefacts (generated per-run, never committed)
build/results-*.json
build/results-*.env
build/yaml-backup/

# Local dev state
*.log
*.tmp
*.swp
*.bak

# Editor / OS noise
.idea/
.vscode/
.DS_Store
Thumbs.db

# Secrets that may be left lying around during local testing. The real
# location on a deployed server is /etc/personal-server/ (outside the repo),
# but be paranoid anyway.
acme.env
coolify-root.txt
keycloak-admin.txt
*.pem
*.key

# Test SSH key (generated per-run by build.sh, never committed)
build/test-preseed/id_*
