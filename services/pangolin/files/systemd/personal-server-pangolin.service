[Unit]
Description=personal-server Pangolin stack (Pangolin + Gerbil + Traefik)
After=docker.service network-online.target
Requires=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/opt/personal-server/pangolin
EnvironmentFile=-/etc/personal-server/pangolin.env
ExecStart=/usr/bin/docker compose up -d
ExecStop=/usr/bin/docker compose down

[Install]
WantedBy=multi-user.target
