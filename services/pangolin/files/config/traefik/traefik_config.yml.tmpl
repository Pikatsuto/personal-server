# Pangolin Traefik config — rendered into ./config/traefik/traefik_config.yml.
# Source: github.com/fosrl/pangolin/install/config/traefik/traefik_config.yml
# (verified 2026-04-11). Two intentional deviations from upstream:
#   1. ACME uses dnsChallenge with ${PS_ACME_DNS_PROVIDER} (Lego provider name)
#      so wildcard certs work.
#   2. Docker provider enabled to discover Coolify-deployed apps via labels.
api:
  insecure: true
  dashboard: true

providers:
  http:
    endpoint: "http://pangolin:3001/api/v1/traefik-config"
    pollInterval: "5s"
  file:
    filename: "/etc/traefik/dynamic_config.yml"
  docker:
    endpoint: "unix:///var/run/docker.sock"
    exposedByDefault: false
    network: coolify
    watch: true

experimental:
  plugins:
    badger:
      moduleName: "github.com/fosrl/badger"
      version: "${PS_BADGER_VERSION}"

log:
  level: "INFO"
  format: "common"
  maxSize: 100
  maxBackups: 3
  maxAge: 3
  compress: true

certificatesResolvers:
  letsencrypt:
    acme:
      dnsChallenge:
        provider: "${PS_ACME_DNS_PROVIDER}"
      email: "${PS_ACME_EMAIL}"
      storage: "/letsencrypt/acme.json"
      caServer: "https://acme-v02.api.letsencrypt.org/directory"

entryPoints:
  web:
    address: ":80"
  websecure:
    address: ":443"
    transport:
      respondingTimeouts:
        readTimeout: "30m"
    http3:
      advertisedPort: 443
    http:
      tls:
        certResolver: "letsencrypt"
      encodedCharacters:
        allowEncodedSlash: true
        allowEncodedQuestionMark: true

serversTransport:
  insecureSkipVerify: true

ping:
  entryPoint: "web"
