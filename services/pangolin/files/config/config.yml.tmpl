# Pangolin core config — rendered into ./config/config.yml at first boot.
# Source: github.com/fosrl/pangolin/install/config/config.yml (verified
# 2026-04-11).
gerbil:
    start_port: 51820
    base_endpoint: "${PS_DOMAIN}"

app:
    dashboard_url: "https://pangolin.${PS_DOMAIN}"
    log_level: "info"
    telemetry:
        anonymous_usage: false

domains:
    domain1:
        base_domain: "${PS_DOMAIN}"

server:
    secret: "${PS_PANGOLIN_SECRET}"
    cors:
        origins: ["https://pangolin.${PS_DOMAIN}"]
        methods: ["GET", "POST", "PUT", "DELETE", "PATCH"]
        allowed_headers: ["X-CSRF-Token", "Content-Type"]
        credentials: false

flags:
    require_email_verification: false
    disable_signup_without_invite: true
    disable_user_create_org: false
    allow_raw_resources: true
