[Unit]
Description=Arcane Docker UI
After=docker.service
Requires=docker.service

[Service]
Type=simple
Restart=on-failure
RestartSec=5s
EnvironmentFile=/etc/personal-server/arcane.env
ExecStartPre=-/usr/bin/docker rm -f personal-server-arcane
ExecStart=/usr/bin/docker run --rm --name personal-server-arcane \
  --network coolify \
  -p 127.0.0.1:3552:3552 \
  -e APP_URL=${APP_URL} \
  -e ENCRYPTION_KEY=${ENCRYPTION_KEY} \
  -e JWT_SECRET=${JWT_SECRET} \
  -e PUID=${PUID} \
  -e PGID=${PGID} \
  -v /var/run/docker.sock:/var/run/docker.sock \
  -v /var/lib/personal-server/arcane:/app/data \
  ghcr.io/getarcaneapp/arcane:latest
ExecStop=/usr/bin/docker stop personal-server-arcane

[Install]
WantedBy=multi-user.target
