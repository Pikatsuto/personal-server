[Unit]
Description=Coolify (reverse-proxied by our Traefik via shared `coolify` network)
After=docker.service personal-server-traefik.service
Requires=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/var/lib/coolify/coolify/source
# Stock Coolify compose + our override that labels the 4 stack containers
# with com.centurylinklabs.watchtower.enable=false. The override is
# installed at first boot by services/coolify/configure.sh into
# /opt/personal-server/coolify/compose.override.yml.
EnvironmentFile=-/var/lib/coolify/coolify/source/.env
ExecStart=/usr/bin/docker compose -f docker-compose.yml -f docker-compose.prod.yml -f /opt/personal-server/coolify/compose.override.yml up -d
ExecStop=/usr/bin/docker compose -f docker-compose.yml -f docker-compose.prod.yml -f /opt/personal-server/coolify/compose.override.yml down

[Install]
WantedBy=multi-user.target
