# Rendered into /var/lib/personal-server/traefik/docker-compose.yml at every boot.
name: traefik
services:
  traefik:
    image: ${IMAGE_TRAEFIK_REF}
    container_name: traefik
    restart: unless-stopped
    labels:
      com.centurylinklabs.watchtower.enable: "false"
    ports:
      - "80:80"
      - "443:443"
      - "127.0.0.1:8080:8080"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - ./traefik.yml:/etc/traefik/traefik.yml:ro
      - ./dynamic:/etc/traefik/dynamic:ro
      - ./letsencrypt:/letsencrypt
    env_file:
      - ./acme.env
    extra_hosts:
      - "host.docker.internal:host-gateway"

  forward-auth:
    image: ${IMAGE_FORWARD_AUTH_REF}
    container_name: traefik-forward-auth
    restart: unless-stopped
    labels:
      com.centurylinklabs.watchtower.enable: "false"
    # Resolve auth.${PS_DOMAIN} to the docker host gateway. Keycloak's
    # announced issuer is the public URL (KC_HOSTNAME), so OIDC discovery
    # must reach Keycloak via that URL to satisfy the issuer-equality
    # check. The public URL → public IP → routers without NAT hairpin
    # would refuse the connection (and even with hairpin it'd be a useless
    # roundtrip). host-gateway sends the request straight to the docker
    # bridge gateway where docker-proxy forwards 443 to our own Traefik.
    extra_hosts:
      - "auth.${PS_DOMAIN}:host-gateway"
    environment:
      SECRET: "${PS_TRAEFIK_FORWARD_AUTH_SECRET}"
      PROVIDER_URI: "https://auth.${PS_DOMAIN}/realms/${PS_KEYCLOAK_REALM}"
      CLIENT_ID: "traefik-forward-auth"
      CLIENT_SECRET: "${PS_TRAEFIK_FORWARD_AUTH_CLIENT_SECRET}"
      COOKIE_DOMAIN: "${PS_DOMAIN}"
      AUTH_HOST: "auth.${PS_DOMAIN}"
      URL_PATH: "/_oauth"
      LOG_LEVEL: info
      INSECURE_COOKIE: "true"

  filebrowser:
    image: ${IMAGE_FILEBROWSER_REF}
    container_name: filebrowser
    restart: unless-stopped
    labels:
      com.centurylinklabs.watchtower.enable: "false"
    # Same OIDC discovery loopback as forward-auth — see comment there.
    extra_hosts:
      - "auth.${PS_DOMAIN}:host-gateway"
    volumes:
      - ./dynamic:/srv
      - ./filebrowser-data:/home/filebrowser/data
    # Quantum reads config from /home/filebrowser/data/config.yaml by default.
    # The data dir (mounted above) also holds the database.db.

networks:
  default:
    name: coolify
    external: true
