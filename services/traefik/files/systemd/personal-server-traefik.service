[Unit]
Description=Traefik (reverse proxy + forward-auth + filebrowser)
After=docker.service personal-server-keycloak.service
Requires=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/var/lib/personal-server/traefik
EnvironmentFile=-/var/lib/personal-server/traefik/acme.env
ExecStart=/usr/bin/docker compose up -d
ExecStop=/usr/bin/docker compose down

[Install]
WantedBy=multi-user.target
